{
  "name": "company-dai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm -F server dev\" \"pnpm -F ui dev\"",
    "build": "pnpm -r --filter='!@company-dai/ui' build && echo 'Note: UI runs in dev mode'",
    "typecheck": "pnpm -r typecheck --ignore-scripts",
    "test": "vitest",
    "db:generate": "pnpm -F @company-dai/db db:generate",
    "db:migrate": "pnpm -F @company-dai/db db:migrate"
  },
  "keywords": [
    "opencode",
    "agent",
    "manager",
    "paperclip"
  ],
  "author": "",
  "license": "ISC",
  "description": "Company-dai - Paperclip-style AI company control plane",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.27",
    "@lexical/link": "^0.44.0",
    "@mdxeditor/editor": "^3.55.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "lexical": "^0.44.0",
    "mermaid": "^11.14.0",
    "vitest": "^2.1.9"
  }
}