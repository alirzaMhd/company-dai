{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleDetection": "force",
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"]
}